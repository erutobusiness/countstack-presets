{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erutobusiness.github.io/countstack-presets/schema/preset.schema.json",
  "title": "GamePreset",
  "description": "A countstack game preset defining counters, multipliers, items, database entries, and more.",
  "type": "object",
  "required": [
    "meta",
    "counters",
    "totalMax",
    "multipliers",
    "multiplierStacking",
    "items",
    "itemsAffectedByMultipliers",
    "manualSteps",
    "database",
    "notes"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "name", "version", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Unique preset identifier. Must match the directory name."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version (e.g. 1.0.0)"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "theme": {
      "$ref": "#/$defs/PresetTheme",
      "description": "Optional two-tone accent colors for the preset"
    },
    "counters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/CounterDefinition"
      }
    },
    "totalMax": {
      "type": "number",
      "description": "Maximum sum across all counters"
    },
    "multipliers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MultiplierDefinition"
      }
    },
    "multiplierStacking": {
      "type": "string",
      "enum": ["multiplicative", "additive"],
      "description": "How multipliers combine"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ItemDefinition"
      }
    },
    "itemsAffectedByMultipliers": {
      "type": "boolean",
      "description": "Whether items are affected by battle multipliers"
    },
    "manualSteps": {
      "$ref": "#/$defs/ManualSteps"
    },
    "database": {
      "type": "object",
      "required": ["entries", "groups"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DatabaseEntry"
          }
        },
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceGroup"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "ColorPair": {
      "type": "object",
      "required": ["light", "dark"],
      "properties": {
        "light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "dark":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
      },
      "description": "A color pair for light and dark modes"
    },
    "PresetTheme": {
      "type": "object",
      "required": ["secondary", "secondaryContainer", "onSecondaryContainer", "tertiary", "tertiaryContainer", "onAccent"],
      "properties": {
        "secondary":            { "$ref": "#/$defs/ColorPair" },
        "secondaryContainer":   { "$ref": "#/$defs/ColorPair" },
        "onSecondaryContainer": { "$ref": "#/$defs/ColorPair" },
        "tertiary":             { "$ref": "#/$defs/ColorPair" },
        "tertiaryContainer":    { "$ref": "#/$defs/ColorPair" },
        "onAccent":             { "$ref": "#/$defs/ColorPair" }
      },
      "description": "Two-tone accent colors. Keys match countstack CSS token names."
    },
    "LocalizedString": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Localized string: { \"ja\": \"...\", \"en\": \"...\", ... }"
    },
    "CounterDefinition": {
      "type": "object",
      "required": ["id", "name", "shortName", "max", "recommended", "defaultDirection", "includeInTotal"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "$ref": "#/$defs/LocalizedString" },
        "shortName": { "type": "string", "minLength": 1 },
        "max": { "type": "number" },
        "recommended": { "type": "number" },
        "goalValue": { "type": "number" },
        "defaultDirection": { "type": "string", "enum": ["up", "down"] },
        "includeInTotal": { "type": "boolean" },
        "unit": { "$ref": "#/$defs/LocalizedString" }
      }
    },
    "MultiplierDefinition": {
      "type": "object",
      "required": ["id", "name", "factor", "scope"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "$ref": "#/$defs/LocalizedString" },
        "factor": { "type": "number" },
        "scope": { "type": "string", "enum": ["source"] }
      }
    },
    "ItemDefinition": {
      "type": "object",
      "required": ["id", "name", "counter", "amount", "maxPerStat"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "$ref": "#/$defs/LocalizedString" },
        "counter": { "type": "string", "minLength": 1 },
        "amount": { "type": "number" },
        "maxPerStat": { "type": ["number", "null"] }
      }
    },
    "ManualSteps": {
      "type": "object",
      "required": ["increments", "decrements"],
      "properties": {
        "increments": {
          "type": "array",
          "items": { "type": "number" }
        },
        "decrements": {
          "type": "array",
          "items": { "type": "number" }
        }
      }
    },
    "DatabaseEntry": {
      "type": "object",
      "required": ["id", "sortOrder", "name", "values", "tags"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sortOrder": { "type": "number" },
        "name": { "$ref": "#/$defs/LocalizedString" },
        "values": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "SourceGroupMember": {
      "type": "object",
      "required": ["name", "level", "values"],
      "properties": {
        "name": { "$ref": "#/$defs/LocalizedString" },
        "level": { "type": "number" },
        "values": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "SourceGroup": {
      "type": "object",
      "required": ["id", "name", "location", "members", "totalValues", "rematchable"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "$ref": "#/$defs/LocalizedString" },
        "location": { "$ref": "#/$defs/LocalizedString" },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceGroupMember" }
        },
        "totalValues": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "rematchable": { "type": "boolean" }
      }
    }
  }
}
