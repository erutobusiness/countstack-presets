{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erutobusiness.github.io/countstack-presets/schema/preset.schema.json",
  "title": "GamePreset",
  "description": "A countstack game preset defining counters, multipliers, items, database entries, and more.",
  "type": "object",
  "required": [
    "meta",
    "counters",
    "totalMax",
    "multipliers",
    "multiplierStacking",
    "items",
    "itemsAffectedByMultipliers",
    "manualSteps",
    "database",
    "goalTemplates",
    "notes"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "name", "version", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Unique preset identifier. Must match the directory name."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version (e.g. 1.0.0)"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "counters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/CounterDefinition"
      }
    },
    "totalMax": {
      "type": "number",
      "description": "Maximum sum across all counters"
    },
    "multipliers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MultiplierDefinition"
      }
    },
    "multiplierStacking": {
      "type": "string",
      "enum": ["multiplicative"],
      "description": "How multipliers combine"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ItemDefinition"
      }
    },
    "itemsAffectedByMultipliers": {
      "type": "boolean",
      "description": "Whether items are affected by battle multipliers"
    },
    "manualSteps": {
      "$ref": "#/$defs/ManualSteps"
    },
    "database": {
      "type": "object",
      "required": ["entries", "groups"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DatabaseEntry"
          }
        },
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceGroup"
          }
        }
      }
    },
    "goalTemplates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/GoalTemplate"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "CounterDefinition": {
      "type": "object",
      "required": ["id", "name", "shortName", "max", "recommended", "defaultDirection", "includeInTotal"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "shortName": { "type": "string", "minLength": 1 },
        "max": { "type": "number" },
        "recommended": { "type": "number" },
        "defaultDirection": { "type": "string", "enum": ["up", "down"] },
        "includeInTotal": { "type": "boolean" }
      }
    },
    "MultiplierDefinition": {
      "type": "object",
      "required": ["id", "name", "factor", "scope"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "factor": { "type": "number" },
        "scope": { "type": "string", "enum": ["battle"] }
      }
    },
    "ItemDefinition": {
      "type": "object",
      "required": ["id", "name", "counter", "amount", "maxPerStat"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "counter": { "type": "string", "minLength": 1 },
        "amount": { "type": "number" },
        "maxPerStat": { "type": "number" }
      }
    },
    "ManualSteps": {
      "type": "object",
      "required": ["increments", "decrements"],
      "properties": {
        "increments": {
          "type": "array",
          "items": { "type": "number" }
        },
        "decrements": {
          "type": "array",
          "items": { "type": "number" }
        }
      }
    },
    "DatabaseEntry": {
      "type": "object",
      "required": ["id", "catalogNumber", "name", "nameEn", "yield", "tags"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "catalogNumber": { "type": "number" },
        "name": { "type": "string", "minLength": 1 },
        "nameEn": { "type": "string", "minLength": 1 },
        "yield": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "SourceGroupMember": {
      "type": "object",
      "required": ["name", "level", "yield"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "level": { "type": "number" },
        "yield": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "SourceGroup": {
      "type": "object",
      "required": ["id", "name", "nameEn", "location", "locationEn", "members", "totalYield", "rematchable"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "nameEn": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "locationEn": { "type": "string", "minLength": 1 },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceGroupMember" }
        },
        "totalYield": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "rematchable": { "type": "boolean" }
      }
    },
    "GoalTemplate": {
      "type": "object",
      "required": ["id", "name", "goals"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "goals": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    }
  }
}
